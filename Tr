-- Кнопка расчёта стоимости трейда
Tradevalue:Button("Trade value [click]", function()
    if game:GetService("Players").LocalPlayer.PlayerGui.AppUI:FindFirstChild("Trade") then
        local player1 = 0
        local player2 = 0

        for i, v in game:GetService("Players").LocalPlayer.PlayerGui.AppUI.Trade.Offerings.Player1Offering.Cards:GetChildren() do
            if v:FindFirstChild("Title") then
                local itemName = v:FindFirstChild("Title").Text.Text
                local foundKey, foundVal, matchType = findItem(itemName, values)
                if foundKey then
                    if matchType ~= "exact" then
                        print("P1 fuzzy match:", itemName, "→", foundKey, "(", matchType, ")")
                    end
                    player1 = player1 + foundVal
                else
                    print("P1 not found:", itemName)
                end
            end
        end

        for i, v in game:GetService("Players").LocalPlayer.PlayerGui.AppUI.Trade.Offerings.Player2Offering.Cards:GetChildren() do
            if v:FindFirstChild("Title") then
                local itemName = v:FindFirstChild("Title").Text.Text
                local foundKey, foundVal, matchType = findItem(itemName, values)
                if foundKey then
                    if matchType ~= "exact" then
                        print("P2 fuzzy match:", itemName, "→", foundKey, "(", matchType, ")")
                    end
                    player2 = player2 + foundVal
                else
                    print("P2 not found:", itemName)
                end
            end
        end

        local textElement = nil
        for i, v in game:GetService("CoreGui").ui.Main.TabFolder:GetChildren() do
            if #v:GetChildren() <= 2 then
                local button = v:FindFirstChild("Button")
                if button then
                    local title = button:FindFirstChild("ButtonTitle")
                    if title then
                        textElement = title
                        break
                    end
                end
            end
        end

        if textElement then
            local difference = player1 - player2
            local val = Abbreviate(math.abs(difference), 3)
            if player1 > player2 then
                textElement.Text = "You lose by: " .. val
            elseif player1 < player2 then
                textElement.Text = "You win by: " .. val
            else
                textElement.Text = "Balance"
            end
        else
            print("Не найден элемент для отображения результата")
        end
    else
        print("Окно трейда не открыто")
    end
end)

local slots = {}
local ins = {["1"]=true,["2"]=true,["3"]=true,["4"]=true,["5"]=true,
             ["6"]=true,["7"]=true,["8"]=true,["9"]=true,["10"]=true}

sl:Button("Save slots", function()
    slots = {}
    pcall(function()
        if not game:GetService("Players").LocalPlayer.PlayerGui.AppUI:FindFirstChild("Trade") then return end
        for i, v in game:GetService("Players").LocalPlayer.PlayerGui.AppUI.Trade.Offerings.Player1Offering.Cards:GetChildren() do
            if not ins[v.Name] then
                table.insert(slots, v.Name)
            end
        end
    end)
end)

sl:Button("Load slots", function()
	local args = {
	false,
	slots
}
game:GetService("ReplicatedStorage"):WaitForChild("TradeUpdateOffering"):FireServer(unpack(args))
end)
