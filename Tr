-- Функция поиска предмета: сначала точное совпадение, потом похожее
local function findItem(itemName, values)
	-- 1. Точное совпадение
	if values[itemName] then
		return itemName, values[itemName], "exact"
	end

	-- 2. Точное совпадение без учёта регистра
	local itemLower = itemName:lower()
	for key, val in pairs(values) do
		if key:lower() == itemLower then
			return key, val, "case-insensitive"
		end
	end

	-- 3. Поиск по словам + Левенштейн как запасной
	local function levenshtein(s, t)
		local m, n = #s, #t
		local d = {}
		for i = 0, m do d[i] = {[0] = i} end
		for j = 0, n do d[0][j] = j end
		for i = 1, m do
			for j = 1, n do
				local cost = s:sub(i,i) == t:sub(j,j) and 0 or 1
				d[i][j] = math.min(d[i-1][j]+1, d[i][j-1]+1, d[i-1][j-1]+cost)
			end
		end
		return d[m][n]
	end

	local itemWords = {}
	for word in itemLower:gmatch("%S+") do
		itemWords[word] = true
	end

	local bestKey = nil
	local bestVal = 0
	local bestScore = -math.huge

	for key, val in pairs(values) do
		local keyLower = key:lower()
		local wordScore = 0

		for word in keyLower:gmatch("%S+") do
			if itemWords[word] then
				wordScore = wordScore + 1
			end
		end

		-- Левенштейн как дополнительный критерий
		local dist = levenshtein(itemLower, keyLower)
		local score = wordScore * 100 - dist  -- слова важнее, расстояние — тайбрейкер

		if score > bestScore then
			bestScore = score
			bestKey = key
			bestVal = val
		end
	end

	if bestScore > -math.huge then
		return bestKey, bestVal, "fuzzy"
	end

	return nil, 0, "not found"
end

